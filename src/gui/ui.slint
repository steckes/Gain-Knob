import { Knob } from "DSL/knob.slint";
import { TextInput } from "DSL/text-input.slint";
import { KeyboardState } from "globals.slint";

export component AppWindow inherits Window {
    preferred-width: 300px;
    preferred-height: 360px;

    min-width: 240px;
    min-height: 290px;

    // Normalized gain value (0.0 – 1.0)
    in-out property <float> gain-value: 0.75;

    // dB display string pushed from Rust each frame
    in-out property <string> gain-db: "0.0 dB";

    // Prevent key events from reaching the host
    in-out property <bool> prevent_key_event_propagation: KeyboardState.prevent_key_event_propagation;

    callback gain-changed(float);
    callback gain-changed-from-string(string);
    callback gain-begin-drag();
    callback gain-end-drag();

    property <float> scale: 1.0;

    changed width => {
        self.scale = min(self.width / 300px, self.height / 360px);
    }
    changed height => {
        self.scale = min(self.width / 300px, self.height / 360px);
    }

    background: #141414;

    VerticalLayout {
        padding: 32px * root.scale;
        spacing: 0px;
        alignment: center;

        // Plugin name header
        Text {
            text: "GAIN";
            color: #ffffff;
            font-size: 13px * root.scale;
            font-weight: 700;
            letter-spacing: 4px * root.scale;
            horizontal-alignment: center;
        }

        // Subtle divider
        Rectangle {
            height: 1px;
            width: 40px * root.scale;
            background: #2a2a2a;
            // centre it manually
            x: (parent.width - self.width) / 2;
        }

        Rectangle { height: 28px * root.scale; }

        // The knob — centred
        HorizontalLayout {
            alignment: center;

            Knob {
                width: 180px * root.scale;
                height: 180px * root.scale;
                value <=> root.gain-value;
                minimum: 0.0;
                maximum: 1.0;

                changed(v) => {
                    root.gain-changed(v);
                }
                begin-drag() => {
                    root.gain-begin-drag();
                }
                end-drag() => {
                    root.gain-end-drag();
                }
            }
        }

        Rectangle { height: 20px * root.scale; }

        // dB readout
        TextInput {
            text: root.gain-db;

            changed(value) => {
                root.gain-begin-drag();
                root.gain-changed-from-string(value);
                root.gain-end-drag();
            }
        }

        Rectangle { height: 4px * root.scale; }

        // "GAIN" label below readout
        Text {
            text: "OUTPUT GAIN";
            color: #555555;
            font-size: 10px * root.scale;
            font-weight: 600;
            letter-spacing: 2px * root.scale;
            horizontal-alignment: center;
        }

        Rectangle { height: 20px * root.scale; }

        // Vendor tag
        Text {
            text: "ADNMRTNS";
            color: #333333;
            font-size: 9px * root.scale;
            horizontal-alignment: center;
        }
    }
}
